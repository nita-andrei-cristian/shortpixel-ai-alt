{
    "repositories": [
        {
            "packagist.org": false,
            "type": "path",
            "url": "../modules/*",
	    "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "shortpixel/notices":">=1.3",
        "shortpixel/build" : "@dev",
				"shortpixel/shortq": ">=1.0",
				"shortpixel/replacer2": ">=2.0"
    },
    "require-dev": {
	"phpunit/phpunit": "^9",
	"mikey179/vfsstream": "^1",
	"10up/wp_mock": "@dev",
        "php-stubs/wp-cli-stubs": "^2.11"

    },
   "autoload": {
       "psr-4": { "SPAATG\\" : "class" , "SPAATG\\Tests\\" : "tests"}
   },
    "scripts": {
        "post-update-cmd" : "\\SPAATG\\Build\\Build::BuildIt",
        "buildSP" : "\\SPAATG\\Build\\Build::BuildIt",
        "buildLoader": "\\SPAATG\\BuildAutoLoader::buildJSON"
    },
    "extra": {
         "targetNamespace" : "ShortPixel"
    }

}
